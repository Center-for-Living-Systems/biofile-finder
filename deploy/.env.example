# Copy this to `.env` and fill in real values. `.env` is GITIGNORED — never commit it.
#   cp .env.example .env  &&  edit .env

# --- NAS (SMB), read-only service account ---
NAS_HOST=psd-gardelnas.uchicago.edu
NAS_SHARE=Expansion
NAS_USER=image_service
NAS_PASS=                 # the image_service password (secret)
NAS_DOMAIN=               # leave BLANK — specifying "adlocal" causes LOGON_FAILURE
NAS_MOUNT=/srv/gardelnas

# --- Public host (this box) ---
PUBLIC_HOST=128.135.108.226

# --- Basic Auth (currently DISABLED; site is public) ---
# To re-enable a login, set these and re-add basic_auth in the Caddyfile.
#AUTH_USER=
#AUTH_PASS=
